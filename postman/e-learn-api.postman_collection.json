              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentName\": \"Ali Updated\",\n  \"studentEmail\": \"ali.updated@mail.com\",\n  \"coursId\": {{coursId}}\n}"
            },
            "url": "{{baseUrl}}/inscriptions/{{inscriptionId}}"
          }
        },
        {
          "name": "DELETE Inscription",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/inscriptions/{{inscriptionId}}"
          }
        }
      ]
    },

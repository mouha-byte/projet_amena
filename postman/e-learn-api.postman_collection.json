            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentName\": \"Ali\",\n  \"studentEmail\": \"ali@mail.com\",\n  \"coursId\": {{coursId}}\n}"
            },
            "url": "{{baseUrl}}/inscriptions"
          }
        },
        {
          "name": "GET Inscription By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/inscriptions/{{inscriptionId}}"

{
  "info": {
    "name": "E-Learn Microservices API",
    "description": "Collection Postman pour tester les APIs via le Gateway (cours, inscriptions, feedbacks, reclamations).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8085" },
    { "key": "coursId", "value": "" },
    { "key": "inscriptionId", "value": "" },
    { "key": "feedbackId", "value": "" },
    { "key": "reclamationId", "value": "" }
  ],
  "item": [
    {
      "name": "Cours",
      "item": [
        {
          "name": "GET All Cours",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/cours"
          }
        },
        {
          "name": "POST Create Cours",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var data = pm.response.json();",
                  "pm.test('Cours id exists', function () {",
                  "    pm.expect(data).to.have.property('id');",
                  "});",
                  "pm.collectionVariables.set('coursId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Java Spring Boot\",\n  \"description\": \"Cours complet\",\n  \"cover\": \"https://img.com/cover.png\",\n  \"video\": \"https://video.com/v1\",\n  \"category\": \"Backend\",\n  \"language\": \"FR\",\n  \"level\": \"BEGINNER\",\n  \"price\": \"99\",\n  \"duration\": \"10h\",\n  \"instructor\": \"Amena\",\n  \"status\": \"PUBLISHED\"\n}"
            },
            "url": "{{baseUrl}}/cours"
          }
        },
        {
          "name": "GET Cours By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/cours/{{coursId}}"
          }
        },
        {
          "name": "GET Cours Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/cours/{{coursId}}/summary"
          }
        },
        {
          "name": "PUT Update Cours",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Java Spring Boot Avance\",\n  \"description\": \"Cours mis a jour\",\n  \"cover\": \"https://img.com/cover2.png\",\n  \"video\": \"https://video.com/v2\",\n  \"category\": \"Backend\",\n  \"language\": \"FR\",\n  \"level\": \"INTERMEDIATE\",\n  \"price\": \"129\",\n  \"duration\": \"12h\",\n  \"instructor\": \"Amena\",\n  \"status\": \"PUBLISHED\"\n}"
            },
            "url": "{{baseUrl}}/cours/{{coursId}}"
          }
        },
        {
          "name": "DELETE Cours",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/cours/{{coursId}}"
          }
        }
      ]
    },
    {
      "name": "Inscriptions",
      "item": [
        {
          "name": "GET All Inscriptions",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/inscriptions"
